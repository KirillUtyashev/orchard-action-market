#!/bin/bash

#=========================================================================================
# SLURM DIRECTIVES
#=========================================================================================
#SBATCH --partition=gpunodes
#SBATCH --job-name=td0_replication
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --gpus-per-task=1
#SBATCH --cpus-per-task=8
#SBATCH --constraint="RTX_4090|RTX_A6000|RTX_A4500|RTX_A4000|RTX_A2000"
#SBATCH --mem=16G
#SBATCH --time=24:00:00
#SBATCH --output=slurm_logs/td0_gpu_%j.out
#SBATCH --error=slurm_logs/td0_gpu_%j.err

#=========================================================================================
# SETUP
#=========================================================================================

echo "Job started on $(hostname) at $(date)"

# 1. Activate Virtual Environment
# (Adjust this if your venv is actually at the root level ../../bin/activate)
source ../../bin/activate 

# 2. SET PYTHON PATH (Crucial Fix)
# We are in debug/tadd_experimetns. We need to add orchard-action-market (../../) to path
# so that "from debug.code.config" works.
export PYTHONPATH=$PYTHONPATH:$(pwd)/../..

#=========================================================================================
# RUN EXPERIMENT
#=========================================================================================

# Note the path: ../code/run_experiments.py
python -u ../code/run_experiments.py \
  --alpha 0.01 \
  --schedule_lr \
  --hidden_dim 16 \
  --num_layers 4 \
  --timesteps 400000 \
  --picker_r -1 \
  --num_eval_states 100 \
  --top_k_num_apples 10 \
  --random_policy \
  --lmda 0

echo "Job finished at $(date)"